---
// src/pages/ventures/urbis.astro
import MainLayout from '../../layouts/MainLayout.astro';
import Header from '../../components/common/Header.astro';
import Footer from '../../components/common/Footer.astro';
---

<MainLayout title="CORTEX | Urbis Infrastructure">
  <div class="bg-cortex-navy min-h-screen text-cortex-light selection:bg-[#3A86FF] selection:text-white font-sans">
    <Header />

    <main class="relative pt-32 pb-20 px-6 overflow-hidden border-b border-white/5">
      <div class="max-w-5xl mx-auto text-center relative z-10">
        
        <div class="inline-flex items-center justify-center gap-3 mb-8">
            <span class="text-xs font-mono text-gray-500 uppercase tracking-widest">Cortex Subsidiary</span>
            <span class="w-8 h-px bg-white/20"></span>
            <span class="text-xs font-mono text-[#3A86FF] bg-[#3A86FF]/10 px-2 py-1 rounded border border-[#3A86FF]/20">NODE 03: PRIVATE BETA</span>
        </div>

        <h1 class="text-6xl md:text-8xl font-space font-bold tracking-tighter text-white mb-6">
          URBIS
        </h1>
        <p class="text-xl md:text-2xl text-gray-400 max-w-3xl mx-auto font-light leading-relaxed">
          A centralized, cross-platform mobile marketplace for real estate, land, and civic hospitality assets.
        </p>
      </div>
    </main>

    <section class="py-24 px-6 bg-[#050914]">
        <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
            
            <div class="space-y-12">
                <div>
                    <h3 class="text-3xl font-space font-bold text-white mb-4">Digitizing the Physical City.</h3>
                    <p class="text-gray-400 leading-relaxed text-lg">
                        The real estate market in emerging cities suffers from opacity, fraud, and analog bottlenecks. Urbis digitizes land assets natively on mobile, leveraging device cameras for strict KYC verification and GPS for transparent property mapping.
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-6">
                    <div class="p-6 bg-[#0B132B] rounded-xl border border-white/5">
                        <div class="text-[#3A86FF] font-bold text-2xl mb-1">Mobile Native</div>
                        <div class="text-xs text-gray-500 uppercase font-mono tracking-widest">iOS & Android</div>
                    </div>
                    <div class="p-6 bg-[#0B132B] rounded-xl border border-white/5">
                        <div class="text-[#3A86FF] font-bold text-2xl mb-1">Verified</div>
                        <div class="text-xs text-gray-500 uppercase font-mono tracking-widest">KYC Ecosystem</div>
                    </div>
                </div>

                <div>
                    <h4 class="text-white font-bold mb-4 font-mono text-sm tracking-widest uppercase">Technical Stack</h4>
                    <div class="flex flex-wrap gap-2">
                        <span class="px-3 py-1 bg-[#3A86FF]/10 border border-[#3A86FF]/30 rounded text-sm text-[#3A86FF] font-medium">React Native (Expo)</span>
                        <span class="px-3 py-1 bg-white/5 border border-white/10 rounded text-sm text-gray-300">Cross-Platform Codebase</span>
                        <span class="px-3 py-1 bg-white/5 border border-white/10 rounded text-sm text-gray-300">Native Geospatial Mapping</span>
                        <span class="px-3 py-1 bg-white/5 border border-white/10 rounded text-sm text-gray-300">Secure Payment Gateways</span>
                    </div>
                </div>
            </div>

            <div class="relative h-[600px] rounded-2xl bg-gradient-to-br from-[#0B132B] to-[#050914] border border-white/10 overflow-hidden shadow-2xl flex items-center justify-center p-8">
                <div class="w-[300px] h-[550px] border-[4px] border-gray-800 bg-black rounded-[3rem] flex flex-col backdrop-blur-md overflow-hidden relative shadow-2xl">
                    <div class="h-8 w-full flex items-center justify-between px-6 pt-2">
                        <span class="text-[10px] font-bold text-white">9:41</span>
                        <div class="flex items-center gap-1">
                            <div class="w-3 h-2 bg-white rounded-sm"></div>
                            <div class="w-4 h-2 bg-white rounded-sm"></div>
                        </div>
                    </div>
                    <div class="p-8 flex-1 flex flex-col items-center justify-center">
                        <div class="text-center">
                            <span class="text-[#3A86FF] font-mono text-sm tracking-widest block mb-4">[ URBIS_APP_RENDER ]</span>
                            <div class="w-16 h-16 mx-auto bg-[#3A86FF]/20 rounded-full flex items-center justify-center mb-4 border border-[#3A86FF]/30">
                                <span class="text-[#3A86FF] font-bold text-2xl">U</span>
                            </div>
                            <p class="text-gray-400 text-xs mt-2 font-mono">React Native Map Interface</p>
                        </div>
                    </div>
                    <div class="h-1 w-1/3 bg-white/30 rounded-full absolute bottom-3 left-1/2 -translate-x-1/2"></div>
                </div>
            </div>

        </div>
    </section>

    <section class="py-24 px-6 border-t border-white/5 bg-[#080e21] text-center">
        <h2 class="text-3xl font-space font-bold text-white mb-6">Join the Private Beta</h2>
        <p class="text-gray-400 mb-8 max-w-2xl mx-auto">Urbis is currently undergoing closed beta testing with verified property managers. Native iOS and Android availability will be announced soon.</p>
        <a href="mailto:partners@cortexguild.com" class="inline-block px-8 py-4 bg-[#3A86FF] text-[#0B132B] font-bold rounded-lg hover:bg-white transition-colors">
            Request Beta Access
        </a>
    </section>

    <Footer />
  </div>
</MainLayout>