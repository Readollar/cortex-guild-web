---
// src/pages/index.astro
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import { Image } from 'astro:assets';

// --- IMAGE IMPORTS ---
// ⚠️ IMPORTANT: These must exist in 'src/assets/images/' or the build will fail.
// If you don't have them yet, comment out the import lines below.
// import heroAbstract from '../assets/images/hero-abstract.png';
// import ridwanHeadshot from '../assets/images/ridwan-headshot.png';
// import partner1 from '../assets/images/partner-1.png'; 
---

<MainLayout title="CORTEX | Digital Systems, Civic Solutions">
  
  <div class="bg-cortex-navy min-h-screen text-cortex-light selection:bg-cortex-blue selection:text-white font-sans">
    <Header />

    <main class="relative pt-32 pb-40 px-6 overflow-hidden border-b border-white/5">
      
      <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-cortex-blue/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/3 pointer-events-none opacity-50"></div>
      
      <div class="max-w-7xl mx-auto relative z-10 grid lg:grid-cols-2 gap-12 items-center">
        
        <div class="text-left">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-cortex-steel border border-white/10 text-xs font-mono text-cortex-blue mb-8 tracking-widest uppercase">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cortex-blue opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-cortex-blue"></span>
            </span>
            System Status: Online
          </div>

          <h1 class="text-5xl md:text-7xl lg:text-8xl font-space font-bold tracking-tighter text-white mb-6 leading-[0.95]">
            Digital Systems. <br />
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cortex-blue to-white">Civic Solutions.</span>
          </h1>

          <p class="text-lg text-gray-400 max-w-xl mb-10 leading-relaxed">
            We architect the digital infrastructure that powers the next generation of African cities. Bridging the gap between rapid innovation and institutional stability.
          </p>

          <div class="flex flex-col sm:flex-row items-start gap-4">
            <a href="#ventures" class="px-8 py-4 bg-white text-cortex-navy font-bold rounded-lg hover:bg-gray-100 transition-colors min-w-[180px] text-center">
              Explore Ventures
            </a>
            <a href="#manifesto" class="px-8 py-4 bg-transparent border border-white/20 text-white font-medium rounded-lg hover:bg-white/5 transition-colors min-w-[180px] text-center">
               The Manifesto
            </a>
          </div>
        </div>

        <div class="relative hidden lg:block h-[600px] w-full">
           <div class="absolute inset-0 bg-gradient-to-tr from-cortex-blue/10 to-transparent rounded-3xl border border-white/5 flex items-center justify-center overflow-hidden backdrop-blur-sm">
              <div class="text-center">
                <span class="block text-cortex-blue font-mono text-xs mb-2 tracking-widest">[ VISUAL_SLOT: 3D_ABSTRACT_NETWORK ]</span>
                <span class="text-white/20 text-xs">Recommended: Abstract geometric nodes or city grid</span>
              </div>
           </div>
        </div>

      </div>
    </main>

    <section id="ventures" class="py-32 px-6 bg-[#080e21]">
      <div class="max-w-7xl mx-auto">
        <div class="mb-20 md:flex items-end justify-between border-b border-white/10 pb-8">
          <div class="max-w-2xl">
            <h2 class="text-4xl font-space font-bold text-white mb-4">The Infrastructure.</h2>
            <p class="text-gray-400 text-lg">We build verticals. Each Cortex product addresses a critical gap in the civic economy.</p>
          </div>
        </div>

        <div class="grid lg:grid-cols-3 gap-8">
          
          <article class="group relative bg-cortex-steel border border-white/5 rounded-2xl p-8 hover:border-cortex-blue/30 transition-all duration-500 hover:-translate-y-1 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"></div>
            
            <div class="relative z-10">
                <div class="h-14 w-14 bg-red-500/10 rounded-xl flex items-center justify-center mb-8 border border-red-500/20 group-hover:bg-red-500/20 transition-colors">
                  <span class="font-space font-bold text-red-500 text-2xl">O</span>
                </div>
                
                <h3 class="text-2xl font-bold text-white mb-2">OYOTIMES</h3>
                <div class="flex items-center gap-3 mb-6">
                    <span class="text-xs font-mono text-red-400 uppercase tracking-wider">Media & Intelligence</span>
                    <span class="h-px w-8 bg-white/10"></span>
                    <span class="text-[10px] bg-red-500/20 text-red-400 px-2 py-0.5 rounded border border-red-500/20">LIVE</span>
                </div>
                
                <p class="text-gray-400 leading-relaxed mb-8 border-l-2 border-white/10 pl-4">
                  The premier digital media platform for Oyo State. Delivering hyper-local journalism, economic intelligence, and event data.
                </p>

                <a href="https://oyotimes.com" target="_blank" class="inline-flex items-center text-sm font-bold text-white hover:text-red-400 transition-colors">
                  Access Platform <span class="ml-2">→</span>
                </a>
            </div>
          </article>

          <article class="group relative bg-cortex-steel border border-white/5 rounded-2xl p-8 hover:border-cortex-blue/30 transition-all duration-500 hover:-translate-y-1 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"></div>
            
            <div class="relative z-10">
                <div class="h-14 w-14 bg-yellow-500/10 rounded-xl flex items-center justify-center mb-8 border border-yellow-500/20 group-hover:bg-yellow-500/20 transition-colors">
                  <span class="font-space font-bold text-yellow-500 text-2xl">U</span>
                </div>
                
                <h3 class="text-2xl font-bold text-white mb-2">UNICORE</h3>
                <div class="flex items-center gap-3 mb-6">
                    <span class="text-xs font-mono text-yellow-400 uppercase tracking-wider">EdTech Systems</span>
                    <span class="h-px w-8 bg-white/10"></span>
                    <span class="text-[10px] bg-yellow-500/20 text-yellow-400 px-2 py-0.5 rounded border border-yellow-500/20">DEV</span>
                </div>
                
                <p class="text-gray-400 leading-relaxed mb-8 border-l-2 border-white/10 pl-4">
                  Next-generation ERP infrastructure for higher education. Streamlining student management, grading, and bursary operations.
                </p>

                <span class="inline-flex items-center text-sm font-bold text-gray-500 cursor-not-allowed">
                  Deployment Pending <span class="ml-2 opacity-50">🔒</span>
                </span>
            </div>
          </article>

          <article class="group relative bg-cortex-steel border border-white/5 rounded-2xl p-8 hover:border-cortex-blue/30 transition-all duration-500 hover:-translate-y-1 overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-b from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl"></div>
            
            <div class="relative z-10">
                <div class="h-14 w-14 bg-cortex-blue/10 rounded-xl flex items-center justify-center mb-8 border border-cortex-blue/20 group-hover:bg-cortex-blue/20 transition-colors">
                  <span class="font-space font-bold text-cortex-blue text-2xl">U</span>
                </div>
                
                <h3 class="text-2xl font-bold text-white mb-2">URBIS</h3>
                <div class="flex items-center gap-3 mb-6">
                    <span class="text-xs font-mono text-cortex-blue uppercase tracking-wider">PropTech Marketplace</span>
                    <span class="h-px w-8 bg-white/10"></span>
                    <span class="text-[10px] bg-cortex-blue/20 text-cortex-blue px-2 py-0.5 rounded border border-cortex-blue/20">BETA</span>
                </div>
                
                <p class="text-gray-400 leading-relaxed mb-8 border-l-2 border-white/10 pl-4">
                  A centralized marketplace for real estate, land, and hospitality. Digitizing land assets and simplifying transactions.
                </p>

                <span class="inline-flex items-center text-sm font-bold text-gray-500 cursor-not-allowed">
                  Private Access Only <span class="ml-2 opacity-50">🔒</span>
                </span>
            </div>
          </article>

        </div>
      </div>
    </section>

    <section id="manifesto" class="py-32 px-6 bg-cortex-navy relative overflow-hidden border-t border-white/5">
        <div class="absolute inset-0 bg-[url('/grid-pattern.svg')] opacity-5 pointer-events-none"></div>

        <div class="max-w-7xl mx-auto relative z-10 grid lg:grid-cols-2 gap-20 items-center">
            
            <div class="space-y-8">
                <h2 class="text-4xl md:text-5xl font-space font-bold text-white leading-tight">Why "Cortex"?</h2>
                <div class="space-y-6 text-lg text-gray-400">
                    <p>In anatomy, the <strong class="text-white">cortex</strong> is the outer layer of the brain responsible for higher thought, processing, and decision making.</p>
                    <p>Cortex Guild acts as the digital processing layer for the city. We ingest the chaos of urban life—housing, education, information—and structure it into usable, efficient systems.</p>
                </div>
                
                <div class="pt-8 flex items-center gap-4">
                    <div class="h-16 w-16 rounded-full bg-gray-700 overflow-hidden border-2 border-cortex-blue/20 relative">
                         <div class="absolute inset-0 bg-gradient-to-br from-gray-600 to-gray-800 flex items-center justify-center">
                            <span class="text-[8px] text-white/40">IMG</span>
                         </div>
                    </div>
                    <div>
                        <div class="text-white font-bold text-lg">Ridwan Awujoola</div>
                        <div class="text-sm text-cortex-blue font-mono">CEO & Chief Architect</div>
                    </div>
                </div>
            </div>

            <div class="grid gap-4">
                <div class="p-6 bg-cortex-steel border border-white/5 rounded-xl hover:bg-white/5 transition-colors">
                    <div class="text-cortex-blue font-mono text-xs mb-2">01 // LOCAL FIRST</div>
                    <h4 class="text-white font-bold text-lg">Context Aware</h4>
                    <p class="text-sm text-gray-400 mt-2">We build specifically for the unique constraints of Tier-2 African cities.</p>
                </div>
                <div class="p-6 bg-cortex-steel border border-white/5 rounded-xl hover:bg-white/5 transition-colors">
                    <div class="text-cortex-blue font-mono text-xs mb-2">02 // INSTITUTIONAL GRADE</div>
                    <h4 class="text-white font-bold text-lg">High Stability</h4>
                    <p class="text-sm text-gray-400 mt-2">Security, uptime, and trust are prioritized over "move fast and break things."</p>
                </div>
            </div>

        </div>
    </section>

    <section class="py-24 px-6 border-t border-white/5 bg-[#050914]">
        <div class="max-w-7xl mx-auto text-center">
            <p class="font-mono text-xs text-gray-500 uppercase tracking-[0.2em] mb-12">Backed by Strategic Partners</p>
            
            <div class="flex flex-wrap justify-center items-center gap-12 opacity-50 grayscale hover:grayscale-0 transition-all duration-500">
                <div class="h-12 w-32 border border-white/10 rounded flex items-center justify-center bg-white/5">
                   <span class="text-[10px] font-bold text-white/30 tracking-widest">PARTNER 01</span>
                </div>
                <div class="h-12 w-32 border border-white/10 rounded flex items-center justify-center bg-white/5">
                   <span class="text-[10px] font-bold text-white/30 tracking-widest">PARTNER 02</span>
                </div>
                <div class="h-12 w-32 border border-white/10 rounded flex items-center justify-center bg-white/5">
                   <span class="text-[10px] font-bold text-white/30 tracking-widest">PARTNER 03</span>
                </div>
            </div>
        </div>
    </section>

    <Footer />
  </div>
</MainLayout>