---
// src/components/common/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-black border-t border-white/10 pt-16 pb-8 px-6">
  <div class="max-w-7xl mx-auto">
    
    <div class="grid md:grid-cols-4 gap-12 mb-16">
      
      <div class="col-span-1 md:col-span-2">
        <a href="/" class="text-xl font-space font-bold tracking-tight text-white flex items-center gap-2 mb-4">
          <div class="w-3 h-3 bg-white rounded-sm"></div>
          CORTEX GUILD
        </a>
        <p class="text-gray-400 text-sm max-w-xs leading-relaxed">
          The Civic Operating System for emerging cities. Building the digital infrastructure that powers the next generation of African urban life.
        </p>
      </div>

      <div>
        <h4 class="text-white font-bold mb-4 font-space">Ecosystem</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="https://oyotimes.com" class="hover:text-white transition-colors">OyoTimes Media</a></li>
          <li><a href="#" class="hover:text-white transition-colors">UniCore EdTech</a></li>
          <li><a href="#" class="hover:text-white transition-colors">EasyRent PropTech</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-bold mb-4 font-space">Corporate</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li><a href="#about" class="hover:text-white transition-colors">Manifesto</a></li>
          <li><a href="#investors" class="hover:text-white transition-colors">Investor Relations</a></li>
          <li><a href="mailto:contact@cortexguild.com" class="hover:text-white transition-colors">Contact Us</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center text-xs text-gray-600">
      
      <div class="mb-4 md:mb-0">
        &copy; {currentYear} Cortex Guild Ltd. All rights reserved.
      </div>

      <div class="flex items-center gap-6 font-mono">
        <span>RC: 9257907</span> <span>OYO, NIGERIA</span>
      </div>

    </div>
  </div>
</footer>