---
// src/components/home/PortfolioGrid.astro

const verticals = [
  {
    name: "OyoTimes",
    category: "Digital Media",
    status: "Operational",
    statusColor: "bg-green-500",
    description: "The premier digital media and events platform for Oyo State. Connecting the community through hyper-local journalism and cultural experiences.",
    link: "https://oyotimes.com",
    external: true
  },
  {
    name: "UniCore",
    category: "EdTech Infrastructure",
    status: "In Development",
    statusColor: "bg-amber-500",
    description: "Next-generation University ERP system designed to streamline student management, grading, and administrative workflows.",
    link: "#",
    external: false
  },
  {
    name: "EasyRent",
    category: "PropTech",
    status: "Beta / Dev",
    statusColor: "bg-blue-500",
    description: "Direct landlord-tenant marketplace eliminating middleman friction. Digital housing solutions for the modern tenant.",
    link: "#",
    external: false
  }
];
---

<section id="portfolio" class="py-24 px-6 relative border-t border-white/5">
  <div class="max-w-7xl mx-auto">
    
    <div class="mb-16 md:flex md:items-end md:justify-between">
      <div class="max-w-xl">
        <h2 class="text-3xl md:text-4xl font-space font-bold text-white mb-4">
          The Ecosystem
        </h2>
        <p class="text-gray-400">
          We do not just build apps; we build verticals. Each Cortex Guild product addresses a specific infrastructure gap in the local economy.
        </p>
      </div>
      
      <div class="hidden md:block text-right">
        <span class="font-mono text-xs text-gray-600 uppercase tracking-widest">
          System Status: <span class="text-green-500">Online</span>
        </span>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {verticals.map((project) => (
        <a 
          href={project.link}
          target={project.external ? "_blank" : "_self"}
          class="group relative bg-[#0A0A0A] border border-white/10 rounded-xl p-8 hover:border-white/30 transition-all duration-300 flex flex-col h-full overflow-hidden"
        >
          <div class="absolute inset-0 bg-gradient-to-br from-white/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="relative z-10 flex justify-between items-start mb-6">
            <div class="bg-white/5 p-3 rounded-lg border border-white/10 group-hover:bg-white/10 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M12 2v20"/><path d="M2 12h20"/><path d="m12 12 4.93-4.93"/><path d="M17.66 17.66 12 12"/><path d="M6.34 6.34 12 12"/><path d="m12 12-4.93 4.93"/></svg>
            </div>
            
            <div class="flex items-center gap-2 px-2 py-1 bg-white/5 rounded text-[10px] uppercase tracking-wider font-medium text-gray-300 border border-white/5">
              <span class={`w-1.5 h-1.5 rounded-full ${project.statusColor} animate-pulse`}></span>
              {project.status}
            </div>
          </div>

          <div class="relative z-10 flex-grow">
            <h3 class="text-xl font-bold text-white mb-2 group-hover:text-blue-200 transition-colors">
              {project.name}
            </h3>
            <p class="text-sm text-gray-500 mb-4 font-mono">
              // {project.category}
            </p>
            <p class="text-sm text-gray-400 leading-relaxed">
              {project.description}
            </p>
          </div>

          <div class="relative z-10 mt-8 flex items-center text-sm font-semibold text-white/50 group-hover:text-white transition-colors">
            {project.external ? "Launch Platform" : "View Project Brief"}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-2 group-hover:translate-x-1 transition-transform"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>