---
// src/components/home/Investors.astro
---

<section id="investors" class="py-24 px-6 border-t border-white/10 bg-[#050505]">
  <div class="max-w-7xl mx-auto text-center">
    
    <h2 class="text-sm font-mono text-gray-500 uppercase tracking-widest mb-12">
      Backed By Strategic Partners
    </h2>

    <div class="flex flex-wrap justify-center items-center gap-12 md:gap-24 opacity-70 grayscale hover:grayscale-0 transition-all duration-500">
      
      <div class="group">
        <div class="h-16 w-48 bg-white/5 border border-white/10 rounded flex items-center justify-center group-hover:bg-white/10 transition-colors">
            <span class="text-white font-space font-bold">A.H. Adeyinka</span>
        </div>
        <p class="text-[10px] text-gray-600 mt-2 tracking-wide uppercase group-hover:text-gray-400">Early Stage Partner</p>
      </div>

      <a href="mailto:invest@cortexguild.com" class="group cursor-pointer">
        <div class="h-16 w-48 border border-dashed border-white/20 rounded flex items-center justify-center hover:border-white/50 transition-colors">
            <span class="text-gray-500 text-sm group-hover:text-white transition-colors">Your Logo Here</span>
        </div>
        <p class="text-[10px] text-gray-600 mt-2 tracking-wide uppercase">Join the Guild</p>
      </a>

    </div>

  </div>
</section>